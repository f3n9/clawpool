# Keycloak OIDC
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/company
KEYCLOAK_CLIENT_ID=openclaw-gateway
KEYCLOAK_CLIENT_SECRET=replace_me

# OpenClaw/OpenAI
OPENCLAW_DEFAULT_OPENAI_KEY=replace_me_default_openai_key
OPENCLAW_DEFAULT_OPENAI_ENDPOINT=https://api.openai.com/v1
OPENCLAW_IDLE_MINUTES=30
OPENCLAW_BASE_CPU=0.8
OPENCLAW_BASE_MEM=1.2g
OPENCLAW_BOOST_CPU=1.5
OPENCLAW_BOOST_MEM=2g
OPENCLAW_STARTUP_MAX_CONCURRENT=4

# Routing and host
OPENCLAW_HOST=openclaw.company.internal
