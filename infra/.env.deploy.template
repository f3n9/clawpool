# =========================
# OpenClaw Enterprise Deploy
# Fill this file, then save as: infra/.env
# =========================

# ===== 1) Keycloak OIDC =====
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
OPENCLAW_OAUTH2_COOKIE_SECRET=

# Use which claim as employee unique id, recommended:
# preferred_username (and map it to employee_id in Keycloak)
OPENCLAW_IDENTITY_CLAIM=preferred_username

# ===== 2) Routing / Domain =====
# Host only, no scheme. Example: claw.hatch.yinxiang.com
OPENCLAW_HOST=

# TLS mode:
# - "offload"  : TLS terminated by upstream gateway/LB
# - "local"    : TLS terminated on this host (need cert files)
OPENCLAW_TLS_MODE=offload

# Only needed when OPENCLAW_TLS_MODE=local
OPENCLAW_TLS_CERT_FILE=
OPENCLAW_TLS_KEY_FILE=

# ===== 3) OpenClaw Container Runtime =====
OPENCLAW_JIT_PROVISION=true
# Optional allow-list. Empty means no restriction.
# Examples:
# OPENCLAW_ALLOWED_EMAIL_DOMAINS=company.com
# OPENCLAW_ALLOWED_GROUPS=openclaw-users,engineering
OPENCLAW_ALLOWED_EMAIL_DOMAINS=
OPENCLAW_ALLOWED_GROUPS=

# Example: ghcr.io/your-org/openclaw
OPENCLAW_IMAGE=
# Example: 1.2.3
OPENCLAW_IMAGE_TAG=latest

# WebGUI internal port exposed by OpenClaw container
OPENCLAW_INSTANCE_PORT=18789

# Container mount paths inside OpenClaw image
OPENCLAW_CONTAINER_DATA_PATH=/app/data
OPENCLAW_CONTAINER_CONFIG_PATH=/app/config
OPENCLAW_CONTAINER_RUNTIME_PATH=/home/node/.openclaw
OPENCLAW_CONTAINER_UID=1000
OPENCLAW_CONTAINER_GID=1000

# Optional custom startup command/args (leave empty if image default entrypoint is correct)
OPENCLAW_STARTUP_CMD=
# Gateway bind mode for per-user containers: loopback|lan|tailnet|auto|custom
OPENCLAW_GATEWAY_BIND=lan
# Optional override for Control UI allowed origin; when empty falls back to https://${OPENCLAW_HOST}
OPENCLAW_CONTROL_UI_ORIGIN=
# Gateway auth mode for per-user OpenClaw instance
OPENCLAW_GATEWAY_AUTH_MODE=trusted-proxy
# Optional static token. Keep empty when using trusted-proxy mode.
OPENCLAW_GATEWAY_AUTH_TOKEN=
# Header that OpenClaw reads from trusted proxy (oauth2-proxy) for user identity
OPENCLAW_GATEWAY_TRUSTED_PROXY_USER_HEADER=x-forwarded-user
# CIDR allow-list recognized as trusted proxy hops
OPENCLAW_GATEWAY_TRUSTED_PROXIES=127.0.0.1/32,172.16.0.0/12

# Docker network for per-user containers. Keep in sync with compose project network.
OPENCLAW_DOCKER_NETWORK=infra_default

# ===== 4) OpenAI Policy =====
# Bootstrap default key (for initial provisioning)
OPENCLAW_DEFAULT_OPENAI_KEY=
OPENCLAW_DEFAULT_OPENAI_ENDPOINT=https://api.openai.com/v1

# Must stay within approved models
OPENCLAW_ALLOWED_MODELS=gpt-5.2,gpt-5.3-codex
OPENCLAW_DEFAULT_OPENAI_MODEL=gpt-5.2
OPENCLAW_HEALTH_TIMEOUT_SECONDS=300
OPENCLAW_RUNNING_READY_SECONDS=20

# Whether to enforce per-user dedicated key before go-live: yes/no
OPENCLAW_REQUIRE_PER_USER_KEY_BEFORE_GO_LIVE=no

# ===== 5) Capacity / Lifecycle =====
OPENCLAW_IDLE_MINUTES=30
OPENCLAW_STARTUP_MAX_CONCURRENT=4

OPENCLAW_BASE_CPU=0.8
OPENCLAW_BASE_MEM=1.2g
OPENCLAW_BOOST_CPU=1.5
OPENCLAW_BOOST_MEM=2g
OPENCLAW_BOOST_THRESHOLD=10

# ===== 6) User Mapping =====
# Optional CSV with at least column: employee_id.
# Not required when OPENCLAW_JIT_PROVISION=true.
OPENCLAW_USERS_CSV=infra/users.csv

# If you have special mapping overrides:
# Keep "none" if no overrides
OPENCLAW_MAPPING_FILE=none

# ===== 7) Deployment Host Paths =====
OPENCLAW_USERS_ROOT=/srv/openclaw/users
OPENCLAW_STATE_DIR=/var/lib/openclaw

# ===== 8) Validation =====
# Install and run k6 load test after deployment: yes/no
OPENCLAW_RUN_K6_AFTER_DEPLOY=no
